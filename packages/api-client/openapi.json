{
  "openapi": "3.1.0",
  "info": {
    "title": "Ethereal Nature API",
    "description": "Contract source of truth for storefront and admin (ADR-0004).",
    "version": "0.1.0"
  },
  "externalDocs": {
    "url": "/"
  },
  "servers": [],
  "tags": [],
  "paths": {
    "/health": {
      "get": {
        "tags": [],
        "summary": "Service health",
        "description": "Reports service liveness and database connectivity.",
        "operationId": "getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        },
        "deprecated": false
      }
    },
    "/products": {
      "get": {
        "tags": [],
        "summary": "List products",
        "description": "Paginated, filterable catalog listing. Archived products are excluded.",
        "operationId": "listProducts",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "1-based page number (default 1)",
            "required": false,
            "deprecated": false,
            "explode": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "title": "Int"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Items per page, 1..100 (default 12)",
            "required": false,
            "deprecated": false,
            "explode": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "title": "Int"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Filter by category",
            "required": false,
            "deprecated": false,
            "explode": false,
            "schema": {
              "$ref": "#/components/schemas/ProductCategoryDto"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Case-insensitive name search",
            "required": false,
            "deprecated": false,
            "explode": false,
            "schema": {
              "type": "string",
              "title": "String"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order (default newest)",
            "required": false,
            "deprecated": false,
            "explode": false,
            "schema": {
              "$ref": "#/components/schemas/ProductSortDto"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "One page of products",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductListResponse"
                }
              }
            }
          }
        },
        "deprecated": false
      }
    },
    "/products/{id}": {
      "get": {
        "tags": [],
        "summary": "Get a product by id",
        "operationId": "getProduct",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Product UUID",
            "required": true,
            "deprecated": false,
            "explode": false,
            "schema": {
              "type": "string",
              "title": "String"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The product",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductResponse"
                }
              }
            }
          },
          "404": {
            "description": "No product with this id",
            "headers": {}
          }
        },
        "deprecated": false
      }
    },
    "/auth/register": {
      "post": {
        "tags": [],
        "summary": "Register a new customer account",
        "operationId": "register",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "201": {
            "description": "Account created and signed in",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid email or password shape",
            "headers": {}
          },
          "409": {
            "description": "Email already registered",
            "headers": {}
          }
        },
        "deprecated": false
      }
    },
    "/auth/login": {
      "post": {
        "tags": [],
        "summary": "Sign in with email and password",
        "operationId": "login",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "description": "Signed in",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "headers": {}
          }
        },
        "deprecated": false
      }
    },
    "/auth/me": {
      "get": {
        "tags": [],
        "summary": "The authenticated user",
        "operationId": "getCurrentUser",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current user",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "headers": {}
          }
        },
        "deprecated": false
      }
    },
    "/auth/users": {
      "get": {
        "tags": [],
        "summary": "All user accounts (admin only)",
        "operationId": "listUsers",
        "parameters": [],
        "responses": {
          "200": {
            "description": "All users",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "headers": {}
          },
          "403": {
            "description": "Requires ADMIN role",
            "headers": {}
          }
        },
        "deprecated": false
      }
    },
    "/cart": {
      "get": {
        "tags": [],
        "summary": "The authenticated user's cart, priced fresh from the catalog",
        "operationId": "getCart",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current server cart",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CartResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "headers": {}
          }
        },
        "deprecated": false
      }
    },
    "/cart/merge": {
      "post": {
        "tags": [],
        "summary": "Merge guest cart lines into the server cart",
        "description": "Sum-then-clamp policy with an adjustments report. Idempotent per mergeId: replaying a processed merge returns the cart unchanged. Client price snapshots are display provenance only — never trusted.",
        "operationId": "mergeCart",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MergeCartRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "description": "Merged cart plus adjustments (dropped / clamped / price-changed)",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MergeCartResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "headers": {}
          }
        },
        "deprecated": false
      }
    },
    "/cart/items": {
      "put": {
        "tags": [],
        "summary": "Set a line's quantity (0 removes the line)",
        "operationId": "setCartItem",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetCartItemRequest"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "description": "Updated cart",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CartResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid token",
            "headers": {}
          },
          "409": {
            "description": "Product unavailable",
            "headers": {}
          }
        },
        "deprecated": false
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "title": "String"
          },
          "database": {
            "type": "string",
            "title": "String"
          }
        },
        "required": [
          "database",
          "status"
        ],
        "title": "HealthResponse"
      },
      "ProductCategoryDto": {
        "type": "string",
        "enum": [
          "OILS",
          "HERBS",
          "CRYSTALS",
          "TEAS"
        ],
        "title": "ProductCategoryDto"
      },
      "ProductSortDto": {
        "type": "string",
        "enum": [
          "newest",
          "name",
          "price-asc",
          "price-desc"
        ],
        "title": "ProductSortDto"
      },
      "ProductResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "title": "String"
          },
          "slug": {
            "type": "string",
            "title": "String"
          },
          "name": {
            "type": "string",
            "title": "String"
          },
          "description": {
            "type": "string",
            "title": "String"
          },
          "priceMinor": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          },
          "currency": {
            "type": "string",
            "title": "String"
          },
          "stock": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          },
          "category": {
            "$ref": "#/components/schemas/ProductCategoryDto"
          },
          "imageUrl": {
            "type": [
              "null",
              "string"
            ],
            "title": "String"
          }
        },
        "required": [
          "category",
          "currency",
          "description",
          "id",
          "name",
          "priceMinor",
          "slug",
          "stock"
        ],
        "title": "ProductResponse"
      },
      "ProductListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductResponse"
            },
            "title": "ArrayList<ProductResponse>"
          },
          "page": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          },
          "totalItems": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          },
          "totalPages": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          }
        },
        "required": [
          "items",
          "page",
          "pageSize",
          "totalItems",
          "totalPages"
        ],
        "title": "ProductListResponse"
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "title": "String"
          },
          "password": {
            "type": "string",
            "title": "String"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "RegisterRequest"
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "title": "String"
          },
          "email": {
            "type": "string",
            "title": "String"
          },
          "role": {
            "$ref": "#/components/schemas/RoleDto"
          }
        },
        "required": [
          "email",
          "id",
          "role"
        ],
        "title": "UserResponse"
      },
      "RoleDto": {
        "type": "string",
        "enum": [
          "CUSTOMER",
          "ADMIN"
        ],
        "title": "RoleDto"
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "title": "String"
          },
          "expiresAtEpochSeconds": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          },
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          }
        },
        "required": [
          "expiresAtEpochSeconds",
          "token",
          "user"
        ],
        "title": "AuthResponse"
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "title": "String"
          },
          "password": {
            "type": "string",
            "title": "String"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest"
      },
      "UserListResponse": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserResponse"
            },
            "title": "ArrayList<UserResponse>"
          }
        },
        "required": [
          "users"
        ],
        "title": "UserListResponse"
      },
      "CartLineResponse": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "title": "String"
          },
          "name": {
            "type": "string",
            "title": "String"
          },
          "quantity": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          },
          "unitPriceMinor": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          },
          "currency": {
            "type": "string",
            "title": "String"
          },
          "stock": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          },
          "available": {
            "type": "boolean",
            "title": "Boolean"
          },
          "lineTotalMinor": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          }
        },
        "required": [
          "available",
          "currency",
          "lineTotalMinor",
          "name",
          "productId",
          "quantity",
          "stock",
          "unitPriceMinor"
        ],
        "title": "CartLineResponse"
      },
      "CartResponse": {
        "type": "object",
        "properties": {
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CartLineResponse"
            },
            "title": "ArrayList<CartLineResponse>"
          },
          "subtotalMinor": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          },
          "currency": {
            "type": "string",
            "title": "String"
          }
        },
        "required": [
          "currency",
          "lines",
          "subtotalMinor"
        ],
        "title": "CartResponse"
      },
      "GuestLineDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "title": "String"
          },
          "quantity": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          },
          "priceSnapshotMinor": {
            "type": [
              "null",
              "integer"
            ],
            "format": "int64",
            "title": "Long"
          }
        },
        "required": [
          "productId",
          "quantity"
        ],
        "title": "GuestLineDto"
      },
      "MergeCartRequest": {
        "type": "object",
        "properties": {
          "mergeId": {
            "type": "string",
            "title": "String"
          },
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GuestLineDto"
            },
            "title": "ArrayList<GuestLineDto>"
          }
        },
        "required": [
          "lines",
          "mergeId"
        ],
        "title": "MergeCartRequest"
      },
      "AdjustmentsDto": {
        "type": "object",
        "properties": {
          "dropped": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DroppedLineDto"
            },
            "title": "ArrayList<DroppedLineDto>"
          },
          "clamped": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClampedLineDto"
            },
            "title": "ArrayList<ClampedLineDto>"
          },
          "priceChanged": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PriceChangeDto"
            },
            "title": "ArrayList<PriceChangeDto>"
          }
        },
        "required": [
          "clamped",
          "dropped",
          "priceChanged"
        ],
        "title": "AdjustmentsDto"
      },
      "DroppedLineDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "title": "String"
          },
          "reason": {
            "$ref": "#/components/schemas/DropReasonDto"
          }
        },
        "required": [
          "productId",
          "reason"
        ],
        "title": "DroppedLineDto"
      },
      "DropReasonDto": {
        "type": "string",
        "enum": [
          "NOT_FOUND",
          "ARCHIVED",
          "OUT_OF_STOCK"
        ],
        "title": "DropReasonDto"
      },
      "ClampedLineDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "title": "String"
          },
          "requestedQuantity": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          },
          "grantedQuantity": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          }
        },
        "required": [
          "grantedQuantity",
          "productId",
          "requestedQuantity"
        ],
        "title": "ClampedLineDto"
      },
      "PriceChangeDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "title": "String"
          },
          "snapshotPriceMinor": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          },
          "currentPriceMinor": {
            "type": "integer",
            "format": "int64",
            "title": "Long"
          }
        },
        "required": [
          "currentPriceMinor",
          "productId",
          "snapshotPriceMinor"
        ],
        "title": "PriceChangeDto"
      },
      "MergeCartResponse": {
        "type": "object",
        "properties": {
          "cart": {
            "$ref": "#/components/schemas/CartResponse"
          },
          "adjustments": {
            "$ref": "#/components/schemas/AdjustmentsDto"
          }
        },
        "required": [
          "adjustments",
          "cart"
        ],
        "title": "MergeCartResponse"
      },
      "SetCartItemRequest": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "title": "String"
          },
          "quantity": {
            "type": "integer",
            "format": "int32",
            "title": "Int"
          }
        },
        "required": [
          "productId",
          "quantity"
        ],
        "title": "SetCartItemRequest"
      }
    },
    "examples": {}
  },
  "webhooks": {}
}
